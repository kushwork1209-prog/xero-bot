logger = logging.getLogger("NEXUS.Utility")


class Utility(commands.Cog):
    def __init__(self, bot):
        self.bot = bot

    @app_commands.command(name="ping", description="Check bot latency, API response, and system performance.")
    async def ping(self, interaction: discord.Interaction):
        latency = round(self.bot.latency * 1000)
        uptime = time.time() - self.bot.launch_time
        uptime_str = f"{int(uptime//86400)}d {int((uptime%86400)//3600)}h {int((uptime%3600)//60)}m"
        try:
            proc = psutil.Process(os.getpid())
            mem = proc.memory_info().rss / 1024 / 1024
            cpu = proc.cpu_percent(interval=0.1)
        except Exception:
            mem, cpu = 0, 0
        rating = "🟢 Excellent" if latency < 80 else ("🟡 Good" if latency < 150 else "🔴 High")
        embed = comprehensive_embed(title="🏓 NEXUS Performance Dashboard", color=discord.Color.blurple())
        embed.add_field(name="⚡ Latency", value=f"**{latency}ms** {rating}", inline=True)
        embed.add_field(name="📡 API", value=f"**{round(self.bot.latency * 1000)}ms**", inline=True)
        embed.add_field(name="💾 Memory", value=f"**{mem:.1f} MB**", inline=True)
        embed.add_field(name="🖥️ CPU", value=f"**{cpu:.1f}%**", inline=True)
        embed.add_field(name="⏱️ Uptime", value=f"**{uptime_str}**", inline=True)
        embed.add_field(name="🌐 Servers", value=f"**{len(self.bot.guilds):,}**", inline=True)
        embed.set_footer(text="NEXUS Bot | All systems nominal")
        await interaction.response.send_message(embed=embed)

    @app_commands.command(name="userinfo", description="Get comprehensive information about a user or yourself.")
    @app_commands.describe(user="User to get info about")
    async def userinfo(self, interaction: discord.Interaction, user: discord.Member = None):
        target = user or interaction.user
        data = await self.bot.db.get_level(target.id, interaction.guild.id)
        eco = await self.bot.db.get_economy(target.id, interaction.guild.id)
        stats = await self.bot.db.get_user_stats(target.id, interaction.guild.id)
        warns = await self.bot.db.get_warnings(interaction.guild.id, target.id)
        badges = []
        if target.id == interaction.guild.owner_id: badges.append("👑 Server Owner")
        if target.guild_permissions.administrator: badges.append("🛡️ Administrator")
        if target.bot: badges.append("🤖 Bot")
        if target.premium_since: badges.append("💎 Server Booster")
        embed = comprehensive_embed(
            title=f"👤 {target.display_name}",
            description=" | ".join(badges) if badges else None,
            color=target.color if target.color.value != 0 else discord.Color.blurple(),
            thumbnail_url=target.display_avatar.url
        )
        embed.add_field(name="📝 Account", value=(
            f"**Username:** {target}\n"
            f"**ID:** `{target.id}`\n"
            f"**Created:** <t:{int(target.created_at.timestamp())}:R>"
        ), inline=True)
        embed.add_field(name="🏠 Server", value=(
            f"**Joined:** <t:{int(target.joined_at.timestamp())}:R>\n"
            f"**Top Role:** {target.top_role.mention}\n"
            f"**Roles:** {len(target.roles)-1}"
        ), inline=True)
        embed.add_field(name="📊 Stats", value=(
            f"**Level:** {data.get('level', 0)} | **XP:** {data.get('total_xp', 0):,}\n"
            f"**Balance:** ${eco.get('wallet', 0) + eco.get('bank', 0):,}\n"
            f"**Warnings:** {len(warns)}"
        ), inline=True)
        await interaction.response.send_message(embed=embed)

    @app_commands.command(name="serverinfo", description="Get comprehensive information about this server.")
