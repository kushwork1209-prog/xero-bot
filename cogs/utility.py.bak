    @app_commands.command(name="remind", description="Set a reminder for yourself.")
    @app_commands.describe(message="What to remind you about", minutes="Minutes from now (max 10080 = 1 week)")
    async def remind(self, interaction: discord.Interaction, message: str, minutes: int = 10):
        minutes = max(1, min(10080, minutes))
        remind_at = (datetime.datetime.now() + datetime.timedelta(minutes=minutes)).isoformat()
        rid = await self.bot.db.add_reminder(interaction.user.id, interaction.channel.id, message, remind_at)
        hrs = minutes // 60
        mins = minutes % 60
        time_str = f"{hrs}h {mins}m" if hrs else f"{mins}m"
        await interaction.response.send_message(embed=success_embed("Reminder Set! ⏰", f"I'll remind you about:\n**{message}**\n\nIn **{time_str}** (Reminder #{rid})"), ephemeral=True)

    @app_commands.command(name="poll", description="Create an interactive poll with up to 4 options.")
    @app_commands.describe(question="Poll question", option1="First option", option2="Second option", option3="Third option (optional)", option4="Fourth option (optional)")
    async def poll(self, interaction: discord.Interaction, question: str, option1: str, option2: str, option3: str = None, option4: str = None):
        options = [opt for opt in [option1, option2, option3, option4] if opt]
        number_emojis = ["1️⃣", "2️⃣", "3️⃣", "4️⃣"]
        embed = discord.Embed(title=f"📊 Poll: {question}", color=discord.Color.blurple())
        for i, opt in enumerate(options):
            embed.add_field(name=f"{number_emojis[i]} Option {i+1}", value=opt, inline=False)
        embed.set_footer(text=f"Poll created by {interaction.user.display_name}")
        msg = await interaction.channel.send(embed=embed)
        for i in range(len(options)):
            await msg.add_reaction(number_emojis[i])
        await interaction.response.send_message(embed=success_embed("Poll Created!", "Your poll has been posted."), ephemeral=True)

    @app_commands.command(name="afk", description="Set yourself as AFK. The bot will notify others who ping you.")
    @app_commands.describe(reason="Reason for being AFK")
