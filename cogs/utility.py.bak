    @app_commands.command(name="timestamp", description="Convert a time to Discord timestamp format.")
    @app_commands.describe(year="Year", month="Month (1-12)", day="Day", hour="Hour (0-23, UTC)", minute="Minute (0-59)")
    async def timestamp(self, interaction: discord.Interaction, year: int, month: int, day: int, hour: int = 0, minute: int = 0):
        try:
            dt = datetime.datetime(year, month, day, hour, minute, tzinfo=datetime.timezone.utc)
            ts = int(dt.timestamp())
            formats = {
                "Short Time": (f"<t:{ts}:t>", f"`<t:{ts}:t>`"),
                "Long Time": (f"<t:{ts}:T>", f"`<t:{ts}:T>`"),
                "Short Date": (f"<t:{ts}:d>", f"`<t:{ts}:d>`"),
                "Long Date": (f"<t:{ts}:D>", f"`<t:{ts}:D>`"),
                "Full Date+Time": (f"<t:{ts}:f>", f"`<t:{ts}:f>`"),
                "Relative": (f"<t:{ts}:R>", f"`<t:{ts}:R>`"),
            }
            embed = info_embed("🕐 Discord Timestamp", f"**Unix:** `{ts}`")
            for fmt_name, (display, code) in formats.items():
                embed.add_field(name=fmt_name, value=f"{display}\n{code}", inline=True)
            await interaction.response.send_message(embed=embed)
        except ValueError:
            await interaction.response.send_message(embed=error_embed("Invalid Date", "Please enter a valid date and time."), ephemeral=True)

    @app_commands.command(name="calc", description="Evaluate a mathematical expression safely.")
    @app_commands.describe(expression="Math expression (e.g. 2+2, sqrt(16), 10^3)")
    async def calc(self, interaction: discord.Interaction, expression: str):
        import math, re
        try:
            # Safe evaluation using math module
            safe_expr = expression.replace("^", "**").replace("×", "*").replace("÷", "/")
            allowed = set("0123456789+-*/().% ")
            math_funcs = {k: v for k, v in vars(math).items() if not k.startswith("_")}
            math_funcs.update({"abs": abs, "round": round, "min": min, "max": max})
            if any(c not in allowed and not c.isalpha() and c not in "(),._" for c in safe_expr):
                raise ValueError("Unsafe expression")
            result = eval(safe_expr, {"__builtins__": {}}, math_funcs)
            if isinstance(result, float) and result.is_integer():
                result = int(result)
            embed = success_embed("🧮 Calculator", f"**Input:** `{expression}`\n**Result:** `{result}`")
        except ZeroDivisionError:
            embed = error_embed("Division by Zero", "You can't divide by zero!")
        except Exception as e:
            embed = error_embed("Invalid Expression", f"Could not evaluate: `{expression}`\nTip: Use `*` for multiply, `**` for power, `sqrt()`, `sin()`, etc.")
        await interaction.response.send_message(embed=embed)

    @app_commands.command(name="emojis", description="List all custom emojis in this server.")
    async def emojis(self, interaction: discord.Interaction):
        if not interaction.guild.emojis:
            return await interaction.response.send_message(embed=info_embed("No Custom Emojis", "This server has no custom emojis."))
        static = [e for e in interaction.guild.emojis if not e.animated]
        animated = [e for e in interaction.guild.emojis if e.animated]
        embed = comprehensive_embed(title=f"🎨 Custom Emojis ({len(interaction.guild.emojis)})", color=discord.Color.blurple())
        if static:
            preview = " ".join(str(e) for e in static[:30])
            embed.add_field(name=f"Static ({len(static)})", value=preview[:1024] or "None", inline=False)
        if animated:
            preview = " ".join(str(e) for e in animated[:30])
            embed.add_field(name=f"Animated ({len(animated)})", value=preview[:1024] or "None", inline=False)
        await interaction.response.send_message(embed=embed)

    @app_commands.command(name="color", description="Preview a color from a hex code with detailed information.")
    @app_commands.describe(hex_code="Hex color code e.g. FF5733 or #FF5733")
    async def color(self, interaction: discord.Interaction, hex_code: str):
        try:
            clean = hex_code.lstrip("#")
            if len(clean) != 6:
                raise ValueError
            r, g, b = int(clean[0:2], 16), int(clean[2:4], 16), int(clean[4:6], 16)
            color_val = discord.Color(int(clean, 16))
            # HSL conversion
            r_, g_, b_ = r/255, g/255, b/255
            cmax, cmin = max(r_, g_, b_), min(r_, g_, b_)
            l = (cmax + cmin) / 2
            s = 0 if cmax == cmin else (cmax - cmin) / (1 - abs(2*l - 1))
            # Complementary
            comp_hex = f"{255-r:02X}{255-g:02X}{255-b:02X}"
            embed = discord.Embed(title=f"🎨 Color: #{clean.upper()}", color=color_val)
            embed.add_field(name="HEX", value=f"`#{clean.upper()}`", inline=True)
            embed.add_field(name="RGB", value=f"`rgb({r}, {g}, {b})`", inline=True)
            embed.add_field(name="HSL", value=f"`hsl({int((cmax-cmin)/(cmax+cmin)*60) if cmax != cmin else 0}°, {int(s*100)}%, {int(l*100)}%)`", inline=True)
            embed.add_field(name="Decimal", value=f"`{int(clean, 16)}`", inline=True)
            embed.add_field(name="Complementary", value=f"`#{comp_hex}`", inline=True)
            embed.add_field(name="Brightness", value="Light 🌤️" if l > 0.5 else "Dark 🌑", inline=True)
            embed.set_image(url=f"https://singlecolorimage.com/get/{clean}/200x80")
            await interaction.response.send_message(embed=embed)
        except (ValueError, Exception):
            await interaction.response.send_message(embed=error_embed("Invalid Color", "Please provide a valid 6-character hex code like `FF5733` or `#1A2B3C`."), ephemeral=True)

    @app_commands.command(name="weather", description="Get current weather for any city using wttr.in.")
    @app_commands.describe(city="City name (e.g. New York, London, Tokyo)")
    async def weather(self, interaction: discord.Interaction, city: str):
        await interaction.response.defer()
        import aiohttp
        try:
            url = f"https://wttr.in/{urllib.parse.quote(city)}?format=j1"
            async with aiohttp.ClientSession() as session:
                async with session.get(url, timeout=aiohttp.ClientTimeout(total=10)) as r:
                    if r.status != 200:
                        return await interaction.followup.send(embed=error_embed("City Not Found", f"Could not find weather data for **{city}**."))
                    data = await r.json()
            current = data["current_condition"][0]
            area = data["nearest_area"][0]
            city_name = area["areaName"][0]["value"]
            country = area["country"][0]["value"]
            temp_c = current["temp_C"]
            temp_f = current["temp_F"]
            feels_c = current["FeelsLikeC"]
            humidity = current["humidity"]
            wind_kph = current["windspeedKmph"]
            desc = current["weatherDesc"][0]["value"]
            visibility = current["visibility"]
            embed = comprehensive_embed(
                title=f"🌤️ Weather — {city_name}, {country}",
                description=f"**{desc}**",
                color=discord.Color.blue()
            )
            embed.add_field(name="🌡️ Temperature", value=f"**{temp_c}°C** / {temp_f}°F", inline=True)
            embed.add_field(name="🤔 Feels Like", value=f"**{feels_c}°C**", inline=True)
            embed.add_field(name="💧 Humidity", value=f"**{humidity}%**", inline=True)
            embed.add_field(name="💨 Wind", value=f"**{wind_kph} km/h**", inline=True)
            embed.add_field(name="👁️ Visibility", value=f"**{visibility} km**", inline=True)
            embed.set_footer(text="Powered by wttr.in | NEXUS Bot")
            await interaction.followup.send(embed=embed)
        except Exception as e:
            await interaction.followup.send(embed=error_embed("Error", f"Could not fetch weather for **{city}**. Try a different city name."))

    @app_commands.command(name="define", description="Look up the definition of any English word.")
    @app_commands.describe(word="Word to define")
    async def define(self, interaction: discord.Interaction, word: str):
        await interaction.response.defer()
        import aiohttp
        try:
            async with aiohttp.ClientSession() as session:
                async with session.get(f"https://api.dictionaryapi.dev/api/v2/entries/en/{urllib.parse.quote(word)}", timeout=aiohttp.ClientTimeout(total=10)) as r:
                    if r.status != 200:
                        return await interaction.followup.send(embed=error_embed("Not Found", f"No definition found for **{word}**."))
                    data = await r.json()
            entry = data[0]
            phonetic = entry.get("phonetic", "")
            embed = comprehensive_embed(
                title=f"📖 Definition: {word.capitalize()}",
                description=phonetic if phonetic else None,
                color=discord.Color.blue()
            )
            for meaning in entry.get("meanings", [])[:3]:
                pos = meaning["partOfSpeech"]
                defs = meaning.get("definitions", [])[:2]
                for d in defs:
                    definition = d.get("definition", "")
                    example = d.get("example", "")
                    value = definition
                    if example:
                        value += f"\n*Example: {example}*"
                    synonyms = d.get("synonyms", [])[:3]
                    if synonyms:
                        value += f"\n**Synonyms:** {', '.join(synonyms)}"
                    embed.add_field(name=f"*{pos}*", value=value[:600], inline=False)
            await interaction.followup.send(embed=embed)
        except Exception:
            await interaction.followup.send(embed=error_embed("Error", f"Could not find a definition for **{word}**."))

    @app_commands.command(name="help", description="Get a full list of all NEXUS commands organized by category.")
    async def help(self, interaction: discord.Interaction):
        embed = comprehensive_embed(
            title="📚 NEXUS — Full Command Reference",
            description="220+ commands organized by category. All premium features, completely free.",
            color=discord.Color.blurple(),
            thumbnail_url=self.bot.user.display_avatar.url
        )
        categories = [
            ("🛡️ /mod", "warn, warnings, clearwarns, kick, ban, unban, softban, timeout, untimeout, purge, slowmode, lock, unlock, nick, history"),
            ("⚙️ /setup", "welcome, farewell, logs, autorole, muterole, leveling, economy, ai-responses, levelup-channel, ai-persona, view"),
            ("💰 Economy", "balance, work, daily, weekly, deposit, withdraw, pay, rob, slots, blackjack, coinflip, shop, buy, rich"),
            ("📊 /levels", "rank, leaderboard, set-xp, add-xp, reset, reward-add, reward-remove, rewards"),
            ("🤖 /ai", "ask, chat, summarize, translate, brainstorm, code-explain, code-debug, sentiment, rewrite, grammar, generate, fact-check, roast, analyze-image, clear-memory"),
            ("🎮 /fun", "8ball, roll, choose, ship, meme, fact, cat, dog, rps, trivia, joke, would-you-rather, never-have-i-ever, fortune, rate"),
            ("🔧 Utility", "ping, userinfo, serverinfo, avatar, banner, roleinfo, channelinfo, botinfo, remind, poll, afk, timestamp, calc, emojis, help"),
            ("🎭 /social", "hug, kiss, pat, slap, cuddle, dance, highfive, wave, bite, poke"),
            ("🎉 /giveaway", "start, end, reroll, list, cancel, edit-prize, winners, delete"),
            ("📢 /announcement", "send, schedule, list, cancel, edit, mention-role, set-channel"),
            ("🎫 /ticket", "setup, create, close, add, remove, transcript, list"),
            ("🎵 /music", "play, pause, resume, stop, skip, queue, nowplaying, volume, shuffle, loop, remove"),
            ("✅ /verify", "setup, config, update-message, update-role, stats, reset"),
            ("📊 /leaderboard", "xp, economy, commands"),
            ("💾 /backup", "create, list, restore, delete, export"),
            ("🤖 /automod", "setup, toggle, anti-spam, anti-links, anti-caps, add-filter, remove-filter, list-filters"),
        ]
        for name, cmds in categories:
            embed.add_field(name=name, value=cmds, inline=False)
        embed.set_footer(text="NEXUS Bot by Team Flame | Premium features, 100% free.")
        await interaction.response.send_message(embed=embed, ephemeral=True)


async def setup(bot):
    await bot.add_cog(Utility(bot))
